__pycache__/
*.pyc
*.egg-info/
.venv/
logs/
outputs/
wandb/
experiments/
.omc/
docs/superpowers/

# npz-replay test fixtures (large binary eval outputs; provenance in SOURCE.txt)
# encoder/  is excluded from this ignore rule so the mini checkpoint can be committed
tests/fixtures/*
!tests/fixtures/encoder/

# omx wiki runtime lock
.omx/registry/.wiki-lock

# omx scratch — intermediate analysis scaffolding, not tracked
.omx/scratch/

# deploy artifacts tree (weights/golden/runtime packs; on disk for docker cp / Mac pull, out of git)
# layout: deploy/<group>/<label>_<YYMMDD_HHMMSS>/ (mirrors logs tree, label-before-date)
# root-anchored: must NOT catch constrained_albc/deploy/ (code) or tests/deploy/
/deploy/
scratch/
