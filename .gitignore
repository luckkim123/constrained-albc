__pycache__/
*.pyc
*.egg-info/
.venv/
logs/
outputs/
wandb/
experiments/
.omc/
docs/superpowers/

# npz-replay test fixtures (large binary eval outputs; provenance in SOURCE.txt)
# encoder/  is excluded from this ignore rule so the mini checkpoint can be committed
tests/fixtures/*
!tests/fixtures/encoder/

# omx wiki runtime lock
.omx/registry/.wiki-lock

# omx scratch — intermediate analysis scaffolding, not tracked
.omx/scratch/

# deploy export artifacts (large binary .npz; keep on disk for docker cp, out of git)
deploy_export_5000/*.npz
